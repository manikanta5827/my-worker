{
	"name": "my-worker",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"types": "wrangler types",

		"db:generate":      "drizzle-kit generate",

		"db:migrate:local": "wrangler d1 migrations apply my-app-db --local",
		"db:migrate:prod":  "wrangler d1 migrations apply my-app-db --remote",

		"db:seed:local":    "wrangler d1 execute my-app-db --local --file=seeds/dev.sql",
		"db:seed:prod":     "wrangler d1 execute my-app-db --remote --file=seeds/dev.sql"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@types/node": "^25.5.0",
		"drizzle-kit": "^0.31.10",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.75.0"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1",
		"hono": "^4.12.8"
	}
}
